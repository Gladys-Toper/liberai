# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Auth
AUTH_SECRET=
AUTH_TRUST_HOST=true

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Provider Selection (swap these to change providers)
PAYMENT_PROVIDER=x402               # x402 | stripe (future)
SPLIT_PROVIDER=oxsplits             # oxsplits | layerzero (future)
CHAIN_PROVIDER=base                 # base | arbitrum | optimism (future)
STORAGE_PROVIDER=supabase           # supabase | gcs (future)

# x402 / Coinbase
FACILITATOR_URL=https://x402.coinbase.com
NEXT_PUBLIC_X402_NETWORK=eip155:8453   # eip155:84532 for Base Sepolia testnet

# Chain + Wallet
PLATFORM_WALLET_ADDRESS=
SERVER_WALLET_PRIVATE_KEY=           # Controller for 0xSplits updateSplit() + distribute()
BASE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Profit Split
LIBERAI_PROFIT_BPS=1000              # 10% of net profit (after costs)

# Cost Tracking
PLATFORM_INFRA_MONTHLY_COST_USD=50   # Fallback flat rate for infra costs
VERCEL_ACCESS_TOKEN=                 # For Vercel billing API
ANTHROPIC_ADMIN_API_KEY=             # For Anthropic cost API
CRON_SECRET=                         # Secures cron endpoint
